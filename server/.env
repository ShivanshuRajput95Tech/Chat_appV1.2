# App environment
NODE_ENV=development
PORT=4000

# Database (local)
# If using docker-compose below, this URI works from your host machine.
DB=mongodb://admin:admin123@localhost:27017/chatapp?authSource=admin

# JWT / Auth
JWTPRIVATEKEY=change_this_to_a_long_random_secret
SALT=10

# Frontend base URL
BASE_URL=http://localhost:5173

# SMTP (email verification)
HOST=smtp.gmail.com
SERVICE=gmail
EMAIL_PORT=587
SECURE=false
SMTP_USER=your_smtp_user@example.com
SMTP_PASS=your_smtp_password

# Optional services
REDIS_URL=redis://localhost:6379
